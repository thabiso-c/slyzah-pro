{
  "expo": {
    "name": "Slyzah Pro",
    "slug": "slyzah-pro",
    "scheme": "slyzah-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#001f3f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.slyzah.pro",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#001f3f"
      },
      "package": "com.slyzah.pro",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "sounds": [
            "./assets/slyzah_alert.mp3"
          ],
          "color": "#FFFFFF"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "36793b52-3b0f-4382-aa29-c3a867184961"
      }
    },
    "owner": "thabilet",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/36793b52-3b0f-4382-aa29-c3a867184961"
    }
  }
}
